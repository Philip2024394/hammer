NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_HAMMEREX_WHATSAPP=

# Canonical site origin (no trailing slash). Required in prod — drives canonical URLs,
# sitemap.xml, robots.txt, RSS feed, OpenGraph URLs and JSON-LD. Defaults to
# http://localhost:3007 if unset, which will produce wrong URLs in deployed builds.
NEXT_PUBLIC_HAMMEREX_SITE_URL=

# ─── Stripe (dormant until flipped on) ────────────────────────────────
# Two flags by design: the SERVER flag controls whether checkout API
# routes work; the PUBLIC flag controls whether the buyer sees the CTA.
# You can deploy with keys present + UI hidden (PUBLIC=false) to test
# the API end-to-end before going live.
STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Bearer secret for /api/admin/orders/[id]/capture
HAMMEREX_ADMIN_SECRET=
